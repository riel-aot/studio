# This file contains example environment variables for the n8n backend workflows.
# These would be configured in your n8n instance's environment.

# --- Database Connection ---
# Connection details for your chosen database (e.g., Supabase Postgres).
DB_HOST="your-db-host"
DB_PORT="5432"
DB_USER="postgres"
DB_PASSWORD="your-db-password"
DB_NAME="postgres"

# --- AI Service API Keys ---
# API key for the AI service you choose to use within n8n.
# e.g., OPENAI_API_KEY="sk-..."

# --- Security ---
# A secret used to validate JWTs received from the frontend.
# This should match the public key part of the token signing certificate from your IdP (MS Entra ID).
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# --- Webhook Configuration ---
# The path for your main webhook trigger in n8n.
# e.g. if your n8n URL is https://n8n.example.com, the full webhook URL would be
# https://n8n.example.com/webhook/classpulse
WEBHOOK_PATH="classpulse"
