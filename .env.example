# ClassPulse Environment Variables Configuration
# Copy this file to .env.local and fill in the values

# Node Environment
NODE_ENV=development

# N8N Webhook URLs
# These URLs point to your n8n workflows that handle backend operations
# Replace with your actual n8n instance URLs
# NEXT_PUBLIC_ prefix is required for client-side access in Next.js

